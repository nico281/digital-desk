<% is_mine = current_user && message.sender_id == current_user.id %>

<div class="flex <%= is_mine ? 'justify-end' : 'justify-start' %> gap-2">
  <% unless is_mine %>
    <%= user_avatar(message.sender, size: :sm, css: "flex-shrink-0") %>
  <% end %>

  <div class="max-w-[75%]">
    <div class="<%= is_mine ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-900' %> rounded-2xl px-4 py-2.5 <%= is_mine ? 'rounded-br-md' : 'rounded-bl-md' %>">
      <% if message.body.present? %>
        <p class="text-sm whitespace-pre-wrap break-words"><%= message.body %></p>
      <% end %>

      <% if message.files.attached? %>
        <div class="<%= message.body.present? ? 'mt-2' : '' %> space-y-2">
          <% message.files.each do |file| %>
            <% if file.content_type.start_with?("image/") %>
              <%= link_to rails_blob_path(file, disposition: "inline"), target: "_blank", class: "block" do %>
                <%= image_tag file.variant(resize_to_limit: [400, 400]), class: "rounded-lg max-w-full", alt: file.filename %>
              <% end %>
            <% else %>
              <%= link_to rails_blob_path(file, disposition: "attachment"), class: "flex items-center gap-2 px-3 py-2 rounded-lg #{is_mine ? 'bg-white/10 hover:bg-white/20' : 'bg-white hover:bg-gray-50'} transition-colors", target: "_blank" do %>
                <svg class="w-5 h-5 flex-shrink-0 <%= is_mine ? 'text-white/70' : 'text-gray-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <span class="text-xs truncate"><%= file.filename %></span>
                <span class="text-xs <%= is_mine ? 'text-white/50' : 'text-gray-400' %> flex-shrink-0"><%= number_to_human_size(file.byte_size) %></span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <p class="text-[10px] text-gray-400 mt-1 <%= is_mine ? 'text-right' : 'text-left' %>">
      <%= message.created_at.strftime("%H:%M") %>
    </p>
  </div>

  <% if is_mine %>
    <%= user_avatar(message.sender, size: :sm, css: "flex-shrink-0") %>
  <% end %>
</div>
