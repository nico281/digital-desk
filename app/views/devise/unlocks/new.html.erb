<% content_for :title, "Desbloquear cuenta" %>

<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-sm card p-8">
    <div class="text-center mb-6">
      <%= link_to root_path do %>
        <div class="inline-flex items-center justify-center w-10 h-10 bg-gray-900 rounded-xl mb-4">
          <span class="text-white font-bold">D</span>
        </div>
      <% end %>
      <h1 class="text-xl font-bold text-gray-900">Desbloquear cuenta</h1>
      <p class="text-sm text-gray-500 mt-1">Te enviaremos instrucciones para desbloquear</p>
    </div>

    <%= form_with model: resource, as: resource_name, url: unlock_path(resource_name), method: :post do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-4">
        <div>
          <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition-all",
              placeholder: "tu@email.com" %>
        </div>

        <%= f.submit "Reenviar instrucciones", class: "w-full btn-primary py-2.5 text-sm cursor-pointer" %>
      </div>
    <% end %>

    <p class="text-center text-xs text-gray-400 mt-6 pt-5 border-t border-gray-100">
      <%= link_to "Volver a iniciar sesión", new_session_path(resource_name), class: "font-medium text-gray-900 hover:underline" %>
    </p>
  </div>
</div>
