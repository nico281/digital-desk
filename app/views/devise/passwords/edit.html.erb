<% content_for :title, "Nueva contraseña" %>

<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-sm card p-8">
    <div class="text-center mb-6">
      <div class="inline-flex items-center justify-center w-10 h-10 bg-gray-900 rounded-xl mb-4">
        <span class="text-white font-bold">D</span>
      </div>
      <h1 class="text-xl font-bold text-gray-900">Nueva contraseña</h1>
      <p class="text-sm text-gray-500 mt-1">Elegí una nueva contraseña</p>
    </div>

    <%= form_with model: resource, as: resource_name, url: password_path(resource_name), method: :put do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="space-y-4">
        <div>
          <%= f.label :password, "Nueva contraseña", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition-all", placeholder: "Mínimo 6 caracteres" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirmar contraseña", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition-all", placeholder: "Repetí tu contraseña" %>
        </div>

        <%= f.submit "Cambiar contraseña", class: "w-full btn-primary py-2.5 text-sm cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
