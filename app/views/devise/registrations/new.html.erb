<% content_for :title, "Crear cuenta" %>

<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-sm card p-8">
    <div class="text-center mb-6">
      <%= link_to root_path do %>
        <div class="inline-flex items-center justify-center w-10 h-10 bg-gray-900 rounded-xl mb-4">
          <span class="text-white font-bold">D</span>
        </div>
      <% end %>
      <h1 class="text-xl font-bold text-gray-900">Creá tu cuenta</h1>
      <p class="text-sm text-gray-500 mt-1">Empezá a conectar con profesionales</p>
    </div>

    <%- if devise_mapping.omniauthable? %>
      <%= button_to user_google_oauth2_omniauth_authorize_path, data: { turbo: false }, class: "w-full inline-flex items-center justify-center gap-3 px-4 py-2.5 border border-gray-200 rounded-xl text-sm text-gray-700 font-medium hover:bg-gray-50 transition-colors" do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Continuar con Google
      <% end %>

      <div class="relative my-5">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-100"></div>
        </div>
        <div class="relative flex justify-center text-xs">
          <span class="bg-white px-3 text-gray-400">o con email</span>
        </div>
      </div>
    <% end %>

    <%= form_with model: resource, as: resource_name, url: registration_path(resource_name) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-4">
        <div>
          <%= f.label :name, "Nombre", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition-all", placeholder: "Tu nombre" %>
        </div>

        <div>
          <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autocomplete: "email", class: "w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition-all", placeholder: "tu@email.com" %>
        </div>

        <div>
          <%= f.label :password, "Contraseña", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition-all", placeholder: "Mínimo 6 caracteres" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirmar contraseña", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition-all", placeholder: "Repetí tu contraseña" %>
        </div>

        <%= f.submit "Crear cuenta", class: "w-full btn-primary py-2.5 text-sm cursor-pointer" %>
      </div>
    <% end %>

    <p class="text-center text-xs text-gray-400 mt-6 pt-5 border-t border-gray-100">
      ¿Ya tenés cuenta?
      <%= link_to "Iniciá sesión", new_session_path(resource_name), class: "font-medium text-gray-900 hover:underline" %>
    </p>
  </div>
</div>
