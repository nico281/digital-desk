<% content_for :title, "Mi cuenta" %>

<div class="page-header">
  <div class="page-header-content">
    <h1 class="page-header-title">Mi cuenta</h1>
    <p class="page-header-subtitle">Configurá tu perfil y contraseña</p>
  </div>
</div>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="card p-8 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-6">Datos personales</h2>

    <%= form_with model: resource, as: resource_name, url: registration_path(resource_name), method: :put do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-4">
        <div>
          <%= f.label :name, "Nombre", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name, autocomplete: "name", class: "w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition-all" %>
        </div>

        <div>
          <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autocomplete: "email", class: "w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition-all" %>
        </div>

        <hr class="border-gray-100">

        <p class="text-sm text-gray-500">Dejá en blanco si no querés cambiar la contraseña</p>

        <div>
          <%= f.label :password, "Nueva contraseña", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition-all", placeholder: "Mínimo 6 caracteres" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirmar nueva contraseña", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition-all" %>
        </div>

        <hr class="border-gray-100">

        <div>
          <%= f.label :current_password, "Contraseña actual", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <p class="text-xs text-gray-400 mb-1">Necesitamos tu contraseña actual para confirmar los cambios</p>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition-all" %>
        </div>

        <%= f.submit "Guardar cambios", class: "btn-primary py-3 px-6 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <div class="card p-8 border-red-200">
    <h2 class="text-lg font-semibold text-red-600 mb-2">Eliminar cuenta</h2>
    <p class="text-sm text-gray-500 mb-4">Esta acción es irreversible. Se borrarán todos tus datos.</p>
    <%= button_to "Eliminar mi cuenta", registration_path(resource_name), method: :delete, data: { turbo_confirm: "¿Estás seguro? Esta acción no se puede deshacer." }, class: "text-sm text-red-600 font-medium hover:text-red-800 cursor-pointer" %>
  </div>
</div>
