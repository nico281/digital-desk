<% other = @conversation.other_user(current_user) %>
<% professional = @conversation.professional %>
<% content_for :title, "Chat con #{other.name}" %>
<% content_for :body_class, "conversations-show" %>

<div class="flex flex-col h-full px-3 sm:px-4 lg:px-6 py-3 sm:py-4 gap-3 sm:gap-4">
  <!-- Header -->
  <div class="card flex-shrink-0">
    <div class="flex items-center justify-between px-4 sm:px-6 py-3 sm:py-4">
      <div class="flex items-center gap-2 sm:gap-3">
        <%= link_to conversations_path, class: "text-gray-400 hover:text-gray-600 p-1 -ml-1", data: { turbo_action: "advance" } do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        <% end %>
        <%= user_avatar(other, size: :md) %>
        <div class="min-w-0">
          <% if other.professional? && other.professional %>
            <%= link_to other.name, professional_path(other.professional), class: "font-semibold text-gray-900 hover:text-violet-600 transition-colors text-sm sm:text-base", data: { turbo_action: "advance" } do %>
              <span class="block truncate"><%= other.name %></span>
            <% end %>
            <p class="text-xs text-gray-500 truncate"><%= other.professional.headline %></p>
          <% else %>
            <p class="font-semibold text-gray-900 text-sm sm:text-base truncate"><%= other.name %></p>
          <% end %>
        </div>
      </div>

      <% if current_user.id == @conversation.client_id && professional %>
        <%= link_to professional_path(professional), class: "btn-primary text-xs sm:text-sm py-1.5 sm:py-2 px-3 sm:px-4 flex-shrink-0", data: { turbo_action: "advance" } do %>
          <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <span class="hidden sm:inline">Reservar</span>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Chat card - ocupa el espacio restante -->
  <div class="card flex-1 min-h-0 overflow-hidden flex flex-col">
    <%= render "shared/chat/chat",
        conversation: @conversation,
        mark_read_url: mark_read_conversation_path(@conversation),
        form_url: conversation_messages_path(@conversation) %>
  </div>
</div>
