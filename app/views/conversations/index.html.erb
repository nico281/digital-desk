<% content_for :title, "Mensajes" %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Mensajes</h1>
  </div>

  <% if @conversations.any? %>
    <div class="card divide-y divide-gray-100">
      <% @conversations.each do |conversation| %>
        <% other = conversation.other_user(current_user) %>
        <% last_msg = conversation.last_message %>
        <% unread = conversation.unread_messages_count_for(current_user) %>

        <%= link_to conversation_path(conversation), class: "flex items-center gap-4 px-6 py-4 hover:bg-gray-50 transition-colors", data: { turbo_action: "advance" } do %>
          <%= user_avatar(other, size: :md) %>

          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between">
              <p class="font-semibold text-gray-900 text-sm truncate"><%= other.name %></p>
              <% if last_msg %>
                <span class="text-xs text-gray-400 flex-shrink-0 ml-2"><%= time_ago_in_words(last_msg.created_at) %></span>
              <% end %>
            </div>
            <% if last_msg %>
              <p class="text-sm text-gray-500 truncate mt-0.5">
                <% if last_msg.sender_id == current_user.id %><span class="text-gray-400">Vos: </span><% end %>
                <%= last_msg.body.present? ? truncate(last_msg.body, length: 60) : "Archivo adjunto" %>
              </p>
            <% else %>
              <p class="text-sm text-gray-400 mt-0.5">Sin mensajes</p>
            <% end %>

            <% if conversation.bookings.any? %>
              <p class="text-xs text-violet-500 mt-1">
                <%= pluralize(conversation.bookings.count, "reserva") %>
              </p>
            <% end %>
          </div>

          <% if unread > 0 %>
            <span class="w-5 h-5 rounded-full bg-violet-600 text-white text-[10px] flex items-center justify-center font-medium flex-shrink-0">
              <%= unread > 9 ? "9+" : unread %>
            </span>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="card p-12 text-center">
      <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
      <p class="text-gray-500">No tenés conversaciones aún</p>
      <p class="text-sm text-gray-400 mt-1">Buscá un profesional y enviá tu primer mensaje</p>
      <%= link_to "Buscar profesionales", search_path, class: "btn-primary text-sm mt-4 inline-block" %>
    </div>
  <% end %>
</div>
