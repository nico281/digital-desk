<% content_for :title, "Buscar profesionales" %>

<div class="page-header">
  <div class="page-header-content">
    <h1 class="page-header-title">Buscar profesionales</h1>
    <p class="page-header-subtitle">Encontrá el experto perfecto para vos</p>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Filters Sidebar -->
    <aside class="w-full lg:w-64 flex-shrink-0">
      <div class="card p-5 sticky top-24">
        <h2 class="font-semibold text-gray-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
          </svg>
          Filtros
        </h2>

        <%= form_tag search_path, method: :get, data: { turbo_frame: "results", controller: "search-filters", turbo_action: "advance" } do %>

          <!-- Category Filter -->
          <div class="mb-5">
            <label class="block text-sm font-medium text-gray-700 mb-2">Categoría</label>
            <select name="category_id" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-gray-300 focus:border-gray-300">
              <option value="">Todas</option>
              <% @categories.each do |cat| %>
                <option value="<%= cat.id %>" <%= params[:category_id] == cat.id.to_s ? "selected" : "" %>><%= cat.name %></option>
              <% end %>
            </select>
          </div>

          <!-- Price Filter -->
          <div class="mb-5">
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Precio máximo: $<%= params[:max_price] || "Cualquiera" %>
            </label>
            <input
              type="range"
              name="max_price"
              min="1000"
              max="50000"
              step="1000"
              value="<%= params[:max_price] || 50000 %>"
              class="w-full"
              data-action="input->search-filters#updatePrice"
            >
          </div>

          <!-- Search Query -->
          <div class="mb-5">
            <label class="block text-sm font-medium text-gray-700 mb-2">Buscar</label>
            <input
              type="text"
              name="q"
              value="<%= params[:q] %>"
              placeholder="Nombre o especialidad"
              class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-gray-300 focus:border-gray-300"
            >
          </div>

          <!-- Sort -->
          <div class="mb-5">
            <label class="block text-sm font-medium text-gray-700 mb-2">Ordenar por</label>
            <select name="sort" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-gray-300 focus:border-gray-300">
              <option value="rating" <%= params[:sort] == "rating" ? "selected" : "" %>>Mejor valorados</option>
              <option value="price_asc" <%= params[:sort] == "price_asc" ? "selected" : "" %>>Precio: menor a mayor</option>
              <option value="price_desc" <%= params[:sort] == "price_desc" ? "selected" : "" %>>Precio: mayor a menor</option>
            </select>
          </div>

          <button type="submit" class="w-full py-2.5 btn-primary">
            Aplicar filtros
          </button>

          <%= link_to "Limpiar", search_path, class: "block w-full text-center py-2 text-sm text-gray-500 hover:text-gray-700 mt-2", data: { turbo_action: "advance" } %>
        <% end %>
      </div>
    </aside>

    <!-- Results -->
    <div class="flex-1">
      <%= turbo_frame_tag "results" do %>
        <div class="flex items-center justify-between mb-6">
          <p class="text-gray-500"><%= @professionals.count %> profesionales encontrados</p>
        </div>

        <% if @professionals.any? %>
          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
            <% @professionals.each do |professional| %>
              <%= render "components/professional_card", professional: %>
            <% end %>
          </div>

          <!-- Pagination -->
          <% if @professionals.respond_to?(:total_pages) && @professionals.total_pages > 1 %>
            <div class="mt-8 flex justify-center">
              <nav class="flex items-center gap-2">
                <% unless @professionals.first_page? %>
                  <%= link_to search_path(request.query_parameters.merge(page: @professionals.current_page - 1), class: "px-3 py-2 rounded-lg border border-gray-200 hover:bg-gray-50", data: { turbo_action: "advance" }) do %>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                  <% end %>
                <% end %>

                <% (1..@professionals.total_pages).each do |page| %>
                  <%= link_to page, search_path(request.query_parameters.merge(page: page)),
                      class: "px-3 py-2 rounded-lg #{page == @professionals.current_page ? "bg-gray-900 text-white" : "border border-gray-200 hover:bg-gray-50"}",
                      data: { turbo_action: "advance" } %>
                <% end %>

                <% unless @professionals.last_page? %>
                  <%= link_to search_path(request.query_parameters.merge(page: @professionals.current_page + 1), class: "px-3 py-2 rounded-lg border border-gray-200 hover:bg-gray-50", data: { turbo_action: "advance" }) do %>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  <% end %>
                <% end %>
              </nav>
            </div>
          <% end %>
        <% else %>
          <%= render "components/empty_state",
              title: "No encontramos profesionales",
              message: "Intentá con otros filtros o términos de búsqueda",
              icon: "search" %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
