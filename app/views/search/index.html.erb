<% content_for :title, @selected_category ? @selected_category.name : "Buscar profesionales" %>

<div class="page-header">
  <div class="page-header-content">
    <% if @selected_category %>
      <div class="flex items-center gap-2 text-gray-400 text-sm mb-2">
        <%= link_to "Buscar", search_path, class: "hover:text-white", data: { turbo_action: "advance" } %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-white"><%= @selected_category.name %></span>
      </div>
    <% end %>
    <h1 class="page-header-title"><%= @selected_category ? @selected_category.name : "Buscar profesionales" %></h1>
    <p class="page-header-subtitle">Encontrá el experto perfecto para vos</p>

    <!-- Search bar -->
    <div class="mt-6 max-w-2xl">
      <%= form_with url: search_path, method: :get, class: "flex gap-2", data: { turbo_action: "advance" } do %>
        <% if @selected_category %>
          <input type="hidden" name="category" value="<%= @selected_category.slug %>">
        <% end %>
        <div class="flex-1 relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input type="text" name="q" value="<%= params[:q] %>"
                 placeholder="Nombre o especialidad..."
                 class="w-full pl-12 pr-4 py-3 bg-white/10 backdrop-blur-sm rounded-xl text-white placeholder-gray-400 border border-white/20 focus:border-white/40 focus:ring-0 focus:outline-none">
        </div>
        <button type="submit" class="px-6 py-3 bg-white text-gray-900 font-medium rounded-xl hover:bg-gray-100 transition-all">
          Buscar
        </button>
      <% end %>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Categories -->
  <div class="mb-8">
    <div class="flex flex-wrap gap-2">
      <%= link_to "Todas", search_path(q: params[:q], sort: params[:sort], max_price: params[:max_price]),
          class: "badge #{@selected_category.blank? ? 'bg-gray-900 text-white' : 'badge-gray hover:bg-gray-200'}",
          data: { turbo_action: "advance" } %>
      <% @categories.each do |cat| %>
        <%= link_to cat.name, search_path(category: cat.slug, q: params[:q], sort: params[:sort], max_price: params[:max_price]),
            class: "badge #{@selected_category&.id == cat.id ? 'bg-gray-900 text-white' : 'badge-gray hover:bg-gray-200'}",
            data: { turbo_action: "advance" } %>
      <% end %>
    </div>

    <!-- Subcategories -->
    <% if @subcategories.any? %>
      <div class="flex flex-wrap gap-2 mt-3 pl-2">
        <% @subcategories.each do |sub| %>
          <%= link_to sub.name, search_path(category: @selected_category.slug, subcategory: sub.slug, q: params[:q], sort: params[:sort]),
              class: "text-sm #{params[:subcategory] == sub.slug ? 'text-gray-900 font-semibold' : 'text-gray-500 hover:text-gray-700'}",
              data: { turbo_action: "advance" } %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Toolbar: count + sort + price -->
  <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <p class="text-gray-500 text-sm"><%= @professionals.count %> profesionales</p>

    <div class="flex items-center gap-3">
      <!-- Price filter -->
      <% if params[:max_price].present? %>
        <%= link_to search_path(category: params[:category], q: params[:q], sort: params[:sort]),
            class: "badge badge-gray hover:bg-gray-200", data: { turbo_action: "advance" } do %>
          Hasta $<%= params[:max_price] %> &times;
        <% end %>
      <% end %>

      <!-- Sort -->
      <div class="flex items-center gap-1 text-sm">
        <%= link_to "Rating", search_path(category: params[:category], q: params[:q], max_price: params[:max_price], sort: "rating"),
            class: "px-3 py-1.5 rounded-lg #{params[:sort].blank? || params[:sort] == 'rating' ? 'bg-gray-100 font-medium text-gray-900' : 'text-gray-500 hover:text-gray-700'}",
            data: { turbo_action: "advance" } %>
        <%= link_to "$ ↑", search_path(category: params[:category], q: params[:q], max_price: params[:max_price], sort: "price_asc"),
            class: "px-3 py-1.5 rounded-lg #{params[:sort] == 'price_asc' ? 'bg-gray-100 font-medium text-gray-900' : 'text-gray-500 hover:text-gray-700'}",
            data: { turbo_action: "advance" } %>
        <%= link_to "$ ↓", search_path(category: params[:category], q: params[:q], max_price: params[:max_price], sort: "price_desc"),
            class: "px-3 py-1.5 rounded-lg #{params[:sort] == 'price_desc' ? 'bg-gray-100 font-medium text-gray-900' : 'text-gray-500 hover:text-gray-700'}",
            data: { turbo_action: "advance" } %>
      </div>
    </div>
  </div>

  <!-- Results -->
  <% if @professionals.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% @professionals.each do |professional| %>
        <%= render "components/professional_card", professional: %>
      <% end %>
    </div>
  <% else %>
    <%= render "components/empty_state",
        title: "No encontramos profesionales",
        message: "Probá con otros filtros o términos de búsqueda",
        icon: "search" %>
  <% end %>
</div>
