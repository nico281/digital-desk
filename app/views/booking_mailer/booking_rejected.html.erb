<div class="header">
  <h1>Reserva no aceptada</h1>
</div>

<p>Hola <%= @client.name %>,</p>

<p>Lamentablemente, <strong><%= @professional.full_name %></strong> no pudo aceptar tu reserva.</p>

<div class="detail">
  <div class="detail-label">Servicio</div>
  <div class="detail-value"><%= @service.title %></div>
</div>

<div class="detail">
  <div class="detail-label">Fecha</div>
  <div class="detail-value"><%= l(@booking.date, format: :long) %></div>
</div>

<p style="margin-top: 24px;">
  <a href="<%= professional_url(@professional) %>" class="btn">Buscar otro horario</a>
</p>
