<% content_for :title, "D-Desk — Profesionales al instante" %>

<!-- Hero Section -->
<section class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900">
  <!-- Decorative elements -->
  <div class="absolute top-20 right-10 w-72 h-72 bg-white/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 left-10 w-96 h-96 bg-gray-600/10 rounded-full blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm text-white text-sm font-medium mb-8 border border-white/20">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
        Plataforma activa
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        Conecta con expertos<br>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-gray-300 to-gray-400">en videollamada</span>
      </h1>

      <p class="text-lg sm:text-xl text-gray-300 mb-10 max-w-xl leading-relaxed">
        Clases, consultas y mentoring 1 a 1. Encontrá al profesional perfecto y reservá en segundos.
      </p>

      <!-- Search Box -->
      <div class="bg-white/10 backdrop-blur-md rounded-2xl p-2 mb-6">
        <%= form_with url: search_path, method: :get, class: "flex flex-col sm:flex-row gap-2", data: { turbo_action: "advance", controller: "search-box" } do %>
          <div class="flex-1 relative">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input
              type="text"
              name="q"
              placeholder='¿Qué buscás? Ej: "clases de matemática"'
              class="w-full pl-12 pr-4 py-4 bg-white rounded-xl text-gray-900 placeholder-gray-400 border-0 focus:ring-2 focus:ring-gray-300 focus:outline-none"
              data-action="keydown->search-box#submit"
            >
          </div>
          <button type="submit" class="px-8 py-4 bg-white text-gray-900 font-semibold rounded-xl hover:bg-gray-100 transition-all hover:shadow-lg whitespace-nowrap">
            Buscar
          </button>
        <% end %>
      </div>

      <!-- Popular searches -->
      <div class="flex flex-wrap gap-2 text-sm text-gray-300">
        <span class="text-white/60">Popular:</span>
        <%= link_to "Matemática", search_path(q: "matematica"), class: "px-3 py-1 rounded-full bg-white/10 hover:bg-white/20 transition-colors", data: { turbo_action: "advance" } %>
        <%= link_to "Psicología", search_path(q: "psicologia"), class: "px-3 py-1 rounded-full bg-white/10 hover:bg-white/20 transition-colors", data: { turbo_action: "advance" } %>
        <%= link_to "Programación", search_path(q: "programacion"), class: "px-3 py-1 rounded-full bg-white/10 hover:bg-white/20 transition-colors", data: { turbo_action: "advance" } %>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="relative border-t border-white/10 bg-white/5 backdrop-blur-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-3 gap-8 text-center">
        <div>
          <p class="text-2xl sm:text-3xl font-bold text-white">+50</p>
          <p class="text-gray-400 text-sm">Categorías</p>
        </div>
        <div>
          <p class="text-2xl sm:text-3xl font-bold text-white">100%</p>
          <p class="text-gray-400 text-sm">Online</p>
        </div>
        <div>
          <p class="text-2xl sm:text-3xl font-bold text-white">24/7</p>
          <p class="text-gray-400 text-sm">Disponibilidad</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Categories Section -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-10">
      <div>
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Explora por categoría</h2>
        <p class="text-gray-500 mt-2">Encontrá exactamente lo que necesitás</p>
      </div>
      <%= link_to search_path, class: "text-gray-700 font-medium hover:text-gray-900 flex items-center gap-1 group", data: { turbo_action: "advance" } do %>
        Ver todas
        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @featured_categories.each do |category| %>
        <%= render "components/category_card", category: %>
      <% end %>
    </div>
  </div>
</section>

<!-- Featured Professionals -->
<section class="py-20 bg-gradient-to-b from-gray-50 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-gray-100 text-gray-700 text-sm font-medium mb-4">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        Destacados
      </div>
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Profesionales recomendados</h2>
      <p class="text-gray-500 mt-2">Expertos verificados con mejores calificaciones</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <% @featured_professionals.each do |professional| %>
        <%= render "components/professional_card", professional: %>
      <% end %>
    </div>

    <div class="mt-12 text-center">
      <%= link_to search_path, class: "inline-flex items-center gap-2 px-8 py-4 bg-gray-900 text-white font-medium rounded-xl hover:bg-gray-800 transition-all hover:shadow-lg", data: { turbo_action: "advance" } do %>
        Ver todos los profesionales
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      <% end %>
    </div>
  </div>
</section>

<!-- How it works -->
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Cómo funciona</h2>
      <p class="text-gray-500 mt-3 text-lg">Tres simples pasos</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-8">
      <!-- Step 1 -->
      <div class="relative text-center">
        <div class="absolute top-8 left-1/2 -translate-x-1/2 w-full h-0.5 bg-gradient-to-r from-gray-200 to-transparent hidden md:block"></div>
        <div class="relative">
          <div class="w-16 h-16 mx-auto mb-5 rounded-2xl bg-gradient-to-br from-gray-800 to-gray-900 flex items-center justify-center text-white text-2xl font-bold shadow-lg shadow-gray-200">1</div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Buscá</h3>
          <p class="text-gray-500 leading-relaxed">Explorá profesionales por categoría, leé reseñas y compará precios</p>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="relative text-center">
        <div class="absolute top-8 left-1/2 -translate-x-1/2 w-full h-0.5 bg-gradient-to-r from-gray-200 to-transparent hidden md:block"></div>
        <div class="relative">
          <div class="w-16 h-16 mx-auto mb-5 rounded-2xl bg-gradient-to-br from-gray-800 to-gray-900 flex items-center justify-center text-white text-2xl font-bold shadow-lg shadow-gray-200">2</div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Reservá</h3>
          <p class="text-gray-500 leading-relaxed">Elegí el horario que mejor te convenga y realizá el pago seguro</p>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="text-center">
        <div class="w-16 h-16 mx-auto mb-5 rounded-2xl bg-gradient-to-br from-gray-800 to-gray-900 flex items-center justify-center text-white text-2xl font-bold shadow-lg shadow-gray-200">3</div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Conectá</h3>
        <p class="text-gray-500 leading-relaxed">Unite a la videollamada en el momento programado</p>
      </div>
    </div>
  </div>
</section>

<!-- Become Professional CTA -->
<section class="py-24 bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 relative overflow-hidden">
  <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-30"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 text-gray-300 text-sm font-medium mb-6">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
        <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
      </svg>
      Para profesionales
    </div>
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
      ¿Tenés experiencia que compartir?
    </h2>
    <p class="text-gray-400 text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
      Compartí tus conocimientos con alumnos de todo el mundo. Fijá tus precios, manejá tu agenda y recibí pagos de forma segura.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <%= link_to "Comenzar ahora", new_user_registration_path, class: "px-8 py-4 bg-white text-gray-900 font-semibold rounded-xl hover:bg-gray-100 transition-all hover:shadow-lg", data: { turbo_action: "advance" } %>
      <%= link_to search_path, class: "px-8 py-4 bg-white/10 text-white font-semibold rounded-xl hover:bg-white/20 transition-all border border-white/10", data: { turbo_action: "advance" } do %>
        Explorar como cliente
      <% end %>
    </div>
  </div>
</section>
