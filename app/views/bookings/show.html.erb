<% content_for :title, "Reserva ##{@booking.id}" %>

<div class="bg-violet-600 border-b border-violet-700">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center gap-2 text-violet-200 text-sm mb-2">
      <%= link_to "Inicio", root_path, class: "hover:text-white", data: { turbo_action: "advance" } %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <%= link_to "Mi Panel", dashboard_path, class: "hover:text-white", data: { turbo_action: "advance" } %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="text-white">Reserva #<%= @booking.id %></span>
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold text-white">Detalles de la reserva</h1>
  </div>
</div>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
    <!-- Status Banner -->
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between
      <%= case @booking.status
          when 'confirmed' then 'bg-green-50'
          when 'pending' then 'bg-yellow-50'
          when 'completed' then 'bg-blue-50'
          else 'bg-gray-50'
          end %>">
      <div class="flex items-center gap-3">
        <div class="w-3 h-3 rounded-full
          <%= case @booking.status
              when 'confirmed' then 'bg-green-500'
              when 'pending' then 'bg-yellow-500'
              when 'completed' then 'bg-blue-500'
              else 'bg-gray-400'
              end %>"></div>
        <span class="font-semibold
          <%= case @booking.status
              when 'confirmed' then 'text-green-700'
              when 'pending' then 'text-yellow-700'
              when 'completed' then 'text-blue-700'
              else 'text-gray-700'
              end %>">
          <%= @booking.status.capitalize %>
        </span>
      </div>

      <% if @booking.pending? && @booking.client == current_user %>
        <%= button_to confirm_booking_path(@booking), method: :post,
            class: "px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-500 transition-colors",
            data: { turbo_confirm: "¿Confirmar esta reserva?" } do %>
          Confirmar reserva
        <% end %>
      <% end %>
    </div>

    <!-- Booking Details -->
    <div class="p-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Service Info -->
        <div>
          <h3 class="text-sm font-medium text-gray-500 mb-2">Servicio</h3>
          <p class="text-lg font-semibold text-gray-900"><%= @booking.service.title %></p>
          <p class="text-gray-600 mt-1"><%= @booking.service.description %></p>
          <p class="text-gray-500 text-sm mt-2">
            Duración: <%= @booking.service.duration_minutes %> minutos
          </p>
        </div>

        <!-- Professional Info -->
        <div>
          <h3 class="text-sm font-medium text-gray-500 mb-2">Profesional</h3>
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center text-white font-semibold">
              <%= @booking.professional.user.name.first.upcase %>
            </div>
            <div>
              <p class="font-semibold text-gray-900"><%= @booking.professional.user.name %></p>
              <p class="text-sm text-gray-500"><%= @booking.professional.headline %></p>
            </div>
          </div>
        </div>

        <!-- Date & Time -->
        <div>
          <h3 class="text-sm font-medium text-gray-500 mb-2">Fecha y hora</h3>
          <p class="text-lg font-semibold text-gray-900">
            <%= @booking.availability_block.date&.strftime("%A, %d de %B de %Y") %>
          </p>
          <p class="text-gray-600">
            <%= @booking.availability_block.start_time&.strftime("%H:%M") %> - <%= @booking.availability_block.end_time&.strftime("%H:%M") %>
          </p>
        </div>

        <!-- Price -->
        <div>
          <h3 class="text-sm font-medium text-gray-500 mb-2">Total</h3>
          <p class="text-2xl font-bold text-gray-900">
            <%= number_to_currency(@booking.service.price, unit: "$", precision: 0) %>
          </p>
          <p class="text-sm text-gray-500">Pagado al confirmar</p>
        </div>
      </div>

      <!-- Actions -->
      <div class="mt-8 pt-6 border-t border-gray-100 flex flex-wrap gap-3">
        <% if @booking.pending? %>
          <%= button_to cancel_booking_path(@booking), method: :post,
              class: "px-4 py-2 border border-red-200 text-red-700 text-sm font-medium rounded-lg hover:bg-red-50 transition-colors",
              data: { turbo_confirm: "¿Estás seguro de cancelar esta reserva?" } do %>
            Cancelar reserva
          <% end %>
        <% end %>

        <%= link_to "Volver al panel", dashboard_path, class: "px-4 py-2 text-gray-700 text-sm font-medium hover:text-gray-900", data: { turbo_action: "advance" } %>
      </div>
    </div>
  </div>

  <!-- Review Section -->
  <% if @booking.completed? && @booking.client == current_user %>
    <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden mt-6">
      <div class="p-6">
        <% if @booking.review.present? %>
          <h3 class="text-lg font-bold text-gray-900 mb-3">Tu reseña</h3>
          <div class="flex items-center gap-1 mb-2">
            <% 5.times do |i| %>
              <svg class="w-5 h-5 <%= i < @booking.review.rating ? 'text-yellow-400' : 'text-gray-200' %>" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            <% end %>
          </div>
          <% if @booking.review.comment.present? %>
            <p class="text-gray-600"><%= @booking.review.comment %></p>
          <% end %>
        <% else %>
          <h3 class="text-lg font-bold text-gray-900 mb-4">Dejá tu reseña</h3>
          <%= form_with model: [@booking, Review.new], url: booking_review_path(@booking), method: :post do |f| %>
            <div class="mb-4" data-controller="star-rating">
              <label class="block text-sm font-medium text-gray-700 mb-2">Calificación</label>
              <div class="flex gap-1" data-star-rating-target="stars">
                <% 5.times do |i| %>
                  <button type="button" data-action="star-rating#rate" data-star-rating-value-param="<%= i + 1 %>"
                    class="text-gray-300 hover:text-yellow-400 transition-colors">
                    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  </button>
                <% end %>
              </div>
              <input type="hidden" name="review[rating]" value="" data-star-rating-target="input">
            </div>

            <div class="mb-4">
              <label class="block text-sm font-medium text-gray-700 mb-2">Comentario (opcional)</label>
              <%= f.text_area :comment, name: "review[comment]",
                  rows: 3, maxlength: 1000,
                  class: "w-full rounded-xl border-gray-300 focus:border-gray-900 focus:ring-gray-900 text-sm",
                  placeholder: "Contá tu experiencia..." %>
            </div>

            <%= f.submit "Enviar reseña", class: "btn-primary text-sm py-2 px-6 cursor-pointer" %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
