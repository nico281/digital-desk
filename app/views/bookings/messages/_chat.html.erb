<%= turbo_stream_from "booking_#{booking.id}_user_#{current_user.id}_messages" %>

<div class="flex flex-col h-full" data-controller="chat" data-chat-url-value="<%= mark_read_booking_path(booking) %>">
  <!-- Messages -->
  <div class="flex-1 overflow-y-auto p-4 space-y-3" data-chat-target="messages" id="messages_booking_<%= booking.id %>">
    <% if booking.messages.any? %>
      <% booking.messages.ordered.includes(:sender, files_attachments: :blob).each do |message| %>
        <%= render "bookings/messages/message", message: message, current_user: current_user %>
      <% end %>
    <% else %>
      <div class="text-center py-8" data-chat-target="empty">
        <svg class="w-10 h-10 text-gray-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        <p class="text-sm text-gray-400">No hay mensajes aún</p>
      </div>
    <% end %>
  </div>

  <!-- Form -->
  <div class="border-t border-gray-200 p-3" id="chat_form_booking_<%= booking.id %>">
    <%= render "bookings/messages/form", booking: booking %>
  </div>
</div>
