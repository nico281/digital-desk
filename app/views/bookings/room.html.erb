<div class="h-full flex flex-col" data-controller="video-room"
  data-video-room-token-url-value="<%= livekit_token_booking_path(@booking) %>">

  <!-- Top bar -->
  <div class="flex items-center justify-between px-6 py-3 bg-gray-900/80 border-b border-white/10">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center text-sm font-semibold">
        <%= @other_participant.name.first.upcase %>
      </div>
      <div>
        <p class="text-sm font-medium"><%= @other_participant.name %></p>
        <p class="text-xs text-gray-400"><%= @booking.service.title %></p>
      </div>
    </div>

    <span class="text-xs text-gray-400" data-video-room-target="status">Conectando...</span>
  </div>

  <!-- Video area -->
  <div class="flex-1 relative flex items-center justify-center p-4">
    <!-- Remote (large) -->
    <div class="flex-1 h-full relative bg-gray-900 rounded-2xl overflow-hidden flex items-center justify-center">
      <video class="w-full h-full object-cover hidden" data-video-room-target="remoteVideo" autoplay playsinline></video>
      <div class="absolute inset-0 flex items-center justify-center" data-video-room-target="remotePlaceholder">
        <div class="text-center">
          <div class="w-20 h-20 rounded-full bg-white/10 flex items-center justify-center text-3xl font-semibold mx-auto mb-3">
            <%= @other_participant.name.first.upcase %>
          </div>
          <p class="text-gray-400 text-sm" data-video-room-target="placeholderText">Esperando a <%= @other_participant.name.split.first %>...</p>
        </div>
      </div>
    </div>

    <!-- Local (small, floating) -->
    <div class="absolute bottom-8 right-8 w-48 aspect-video bg-gray-800 rounded-xl overflow-hidden shadow-2xl border border-white/10">
      <video class="w-full h-full object-cover" data-video-room-target="localVideo" autoplay muted playsinline></video>
      <span class="absolute bottom-1.5 left-2 text-xs bg-black/60 text-white px-1.5 py-0.5 rounded">Vos</span>
    </div>
  </div>

  <!-- Controls -->
  <div class="flex items-center justify-center gap-3 px-6 py-5 bg-gray-900/80 border-t border-white/10">
    <button data-action="video-room#toggleAudio" data-video-room-target="micBtn"
      class="w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors cursor-pointer"
      title="Micrófono">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
      </svg>
    </button>

    <button data-action="video-room#toggleVideo" data-video-room-target="camBtn"
      class="w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors cursor-pointer"
      title="Cámara">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
      </svg>
    </button>

    <%= link_to booking_path(@booking), data: { action: "video-room#leave", turbo: false },
      class: "w-14 h-14 rounded-full bg-red-600 hover:bg-red-500 flex items-center justify-center transition-colors cursor-pointer",
      title: "Salir de la llamada" do %>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 8l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2M5 3a2 2 0 00-2 2v1c0 8.284 6.716 15 15 15h1a2 2 0 002-2v-3.28a1 1 0 00-.684-.948l-4.493-1.498a1 1 0 00-1.21.502l-1.13 2.257a11.042 11.042 0 01-5.516-5.516l2.257-1.13a1 1 0 00.502-1.21L9.228 3.683A1 1 0 008.279 3H5z"/>
      </svg>
    <% end %>
  </div>
</div>
