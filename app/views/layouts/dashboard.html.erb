<!DOCTYPE html>
<html class="scroll-smooth">
  <head>
    <title><%= content_for(:title) || "D-Desk" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <meta name="view-transition" content="same-origin" />
  </head>

  <body class="bg-gray-50 text-gray-900 antialiased">
    <%= render "components/navbar", mode: :slim %>

    <div id="flash">
      <%= render "components/toast" %>
    </div>

    <div class="flex">
      <!-- Sidebar -->
      <aside class="hidden lg:flex lg:w-64 lg:flex-col bg-white border-r border-gray-200 overflow-y-auto sticky top-16 h-[calc(100vh-64px)]">
        <div class="p-4">
          <!-- Main Navigation -->
          <nav class="space-y-1">
            <%= link_to dashboard_path, class: dash_nav_class("/dashboard"), data: { turbo_action: "advance" } do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              Panel principal
            <% end %>

            <%= link_to account_path, class: dash_nav_class("/account"), data: { turbo_action: "advance" } do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Mi cuenta
            <% end %>

            <%= link_to conversations_path, class: dash_nav_class("/conversations"), data: { turbo_action: "advance" } do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              Mensajes
            <% end %>

            <%= link_to search_path, class: dash_nav_class("/buscar"), data: { turbo_action: "advance" } do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              Buscar profesionales
            <% end %>

    <% if @wizard %>
            <% elsif current_user.professional&.setup_complete? %>
              <div class="pt-4 pb-2">
                <h3 class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Panel Profesional</h3>
              </div>

              <%= link_to pro_setup_path, class: dash_nav_class("/pro/setup"), data: { turbo_action: "advance" } do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                Mi perfil
              <% end %>

              <%= link_to pro_services_path, class: dash_nav_class("/pro/services"), data: { turbo_action: "advance" } do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                </svg>
                Servicios
              <% end %>

              <%= link_to pro_availability_schedules_path, class: dash_nav_class("/pro/availability_schedules"), data: { turbo_action: "advance" } do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                Disponibilidad
              <% end %>

              <%= link_to pro_bookings_path, class: dash_nav_class("/pro/bookings"), data: { turbo_action: "advance" } do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                </svg>
                Reservas
              <% end %>

              <%= link_to pro_reviews_path, class: dash_nav_class("/pro/reviews"), data: { turbo_action: "advance" } do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519 4.674z"/>
                </svg>
                Reseñas
              <% end %>
            <% else %>
              <div class="mt-4 p-4 bg-gradient-to-br from-violet-50 to-indigo-50 rounded-xl border border-violet-100">
                <% if current_user.professional %>
                  <p class="text-sm text-violet-900 font-medium mb-1">Completá tu perfil profesional</p>
                  <p class="text-xs text-violet-600 mb-3">Terminá la configuración para empezar a recibir clientes</p>
                <% else %>
                  <p class="text-sm text-violet-900 font-medium mb-1">¿Querés ofrecer tus servicios?</p>
                  <p class="text-xs text-violet-600 mb-3">Creá tu perfil profesional</p>
                <% end %>
                <%= link_to pro_setup_path(step: current_user.professional&.next_setup_step || 1), class: "inline-flex items-center gap-2 px-3 py-2 bg-violet-600 text-white text-sm font-medium rounded-lg hover:bg-violet-700 transition-colors", data: { turbo_action: "advance" } do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                  </svg>
                  Empezar
                <% end %>
              </div>
            <% end %>
          </nav>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 min-w-0 pb-20 lg:pb-0">
        <%= yield %>
      </main>
    </div>

    <!-- Bottom Nav (mobile only) -->
    <nav class="fixed bottom-0 inset-x-0 bg-white/80 backdrop-blur-md border-t border-gray-200 lg:hidden z-40">
      <div class="flex items-center justify-around h-16 px-2">
        <%= link_to dashboard_path, class: "flex flex-col items-center gap-0.5 px-2 py-1 rounded-lg text-xs font-medium #{request.path == '/dashboard' ? 'text-gray-900' : 'text-gray-400'}", data: { turbo_action: "advance" } do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          Panel
        <% end %>

        <%= link_to conversations_path, class: "flex flex-col items-center gap-0.5 px-2 py-1 rounded-lg text-xs font-medium #{request.path.start_with?('/conversations') ? 'text-gray-900' : 'text-gray-400'}", data: { turbo_action: "advance" } do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
          Mensajes
        <% end %>

        <%= link_to search_path, class: "flex flex-col items-center gap-0.5 px-2 py-1 rounded-lg text-xs font-medium #{request.path.start_with?('/buscar') ? 'text-gray-900' : 'text-gray-400'}", data: { turbo_action: "advance" } do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          Buscar
        <% end %>

        <% if @wizard %>
          <%# During wizard: only show basic nav, no pro items %>
        <% elsif current_user.professional&.setup_complete? %>
          <%= link_to pro_services_path, class: "flex flex-col items-center gap-0.5 px-2 py-1 rounded-lg text-xs font-medium #{request.path.start_with?('/pro/services') ? 'text-gray-900' : 'text-gray-400'}", data: { turbo_action: "advance" } do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
            </svg>
            Servicios
          <% end %>

          <%= link_to pro_bookings_path, class: "flex flex-col items-center gap-0.5 px-2 py-1 rounded-lg text-xs font-medium #{request.path.start_with?('/pro/bookings') ? 'text-gray-900' : 'text-gray-400'}", data: { turbo_action: "advance" } do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
            Reservas
          <% end %>

          <!-- More menu -->
          <% more_active = request.path.start_with?('/pro/setup') || request.path.start_with?('/pro/reviews') || request.path.start_with?('/pro/availability') %>
          <div class="relative" data-controller="toggle" data-toggle-target-value="bottom-more-menu">
            <button type="button" data-action="toggle#toggle" class="flex flex-col items-center gap-0.5 px-2 py-1 rounded-lg text-xs font-medium <%= more_active ? 'text-gray-900' : 'text-gray-400' %>">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z"/>
              </svg>
              Más
            </button>
            <div id="bottom-more-menu" class="hidden absolute bottom-full right-0 mb-2 w-48 bg-white rounded-xl border border-gray-200 shadow-lg overflow-hidden">
              <%= link_to pro_reviews_path, class: "flex items-center gap-3 px-4 py-3 text-sm #{ request.path.start_with?('/pro/reviews') ? 'text-gray-900 font-semibold bg-gray-50' : 'text-gray-700 hover:bg-gray-50' }", data: { turbo_action: "advance" } do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                </svg>
                Reseñas
              <% end %>
              <%= link_to pro_availability_schedules_path, class: "flex items-center gap-3 px-4 py-3 text-sm border-t border-gray-100 #{ request.path.start_with?('/pro/availability') ? 'text-gray-900 font-semibold bg-gray-50' : 'text-gray-700 hover:bg-gray-50' }", data: { turbo_action: "advance" } do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                Disponibilidad
              <% end %>
              <%= link_to pro_setup_path, class: "flex items-center gap-3 px-4 py-3 text-sm border-t border-gray-100 #{ request.path.start_with?('/pro/setup') ? 'text-gray-900 font-semibold bg-gray-50' : 'text-gray-700 hover:bg-gray-50' }", data: { turbo_action: "advance" } do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                Perfil
              <% end %>
            </div>
          </div>
        <% else %>
          <%= link_to pro_setup_path(step: current_user.professional&.next_setup_step || 1), class: "flex flex-col items-center gap-0.5 px-2 py-1 rounded-lg text-xs font-medium text-violet-600", data: { turbo_action: "advance" } do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            <span><%= current_user.professional ? 'Continuar' : 'Ser Pro' %></span>
          <% end %>
        <% end %>
      </div>
    </nav>
  </body>
</html>
