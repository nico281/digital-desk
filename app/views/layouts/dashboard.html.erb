<!DOCTYPE html>
<html class="scroll-smooth">
  <head>
    <title><%= content_for(:title) || "D-Desk" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <meta name="view-transition" content="same-origin" />
  </head>

  <body class="bg-gray-50 text-gray-900 antialiased">
    <%= render "components/navbar", mode: :slim %>

    <div id="flash">
      <%= render "components/toast" %>
    </div>

    <div class="flex">
      <!-- Sidebar -->
      <aside class="hidden lg:flex lg:w-64 lg:flex-col bg-white border-r border-gray-200 overflow-y-auto sticky top-16 h-[calc(100vh-64px)]">
        <div class="p-4">
          <!-- Main Navigation -->
          <nav class="space-y-1">
            <%= link_to dashboard_path, class: dash_nav_class("/dashboard"), data: { turbo_action: "advance" } do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              Panel principal
            <% end %>

            <%= link_to search_path, class: dash_nav_class("/buscar"), data: { turbo_action: "advance" } do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              Buscar profesionales
            <% end %>

            <% if current_user.professional %>
              <div class="pt-4 pb-2">
                <h3 class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Panel Profesional</h3>
              </div>

              <%= link_to pro_setup_path, class: dash_nav_class("/pro/setup"), data: { turbo_action: "advance" } do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                Mi perfil
              <% end %>

              <%= link_to pro_services_path, class: dash_nav_class("/pro/services"), data: { turbo_action: "advance" } do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                </svg>
                Servicios
              <% end %>

              <%= link_to pro_availability_schedules_path, class: dash_nav_class("/pro/availability_schedules"), data: { turbo_action: "advance" } do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                Disponibilidad
              <% end %>

              <%= link_to pro_bookings_path, class: dash_nav_class("/pro/bookings"), data: { turbo_action: "advance" } do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                </svg>
                Reservas
              <% end %>
            <% else %>
              <!-- Pro CTA -->
              <div class="mt-4 p-4 bg-gradient-to-br from-violet-50 to-indigo-50 rounded-xl border border-violet-100">
                <p class="text-sm text-violet-900 font-medium mb-1">¿Querés ofrecer tus servicios?</p>
                <p class="text-xs text-violet-600 mb-3">Creá tu perfil profesional</p>
                <%= link_to pro_setup_path, class: "inline-flex items-center gap-2 px-3 py-2 bg-violet-600 text-white text-sm font-medium rounded-lg hover:bg-violet-700 transition-colors", data: { turbo_action: "advance" } do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                  </svg>
                  Empezar
                <% end %>
              </div>
            <% end %>
          </nav>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 min-w-0">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
