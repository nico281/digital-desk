<!DOCTYPE html>
<html class="scroll-smooth">
  <head>
    <title><%= content_for(:title) || "D-Desk" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- View Transitions -->
    <meta name="view-transition" content="same-origin" />
  </head>

  <body class="bg-gray-50 text-gray-900 antialiased h-screen flex flex-col overflow-hidden">
    <%= render "components/navbar" %>

    <% if notice.present? %>
      <div class="bg-green-50 border-b border-green-200 px-4 py-3 text-sm text-green-800 text-center"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="bg-red-50 border-b border-red-200 px-4 py-3 text-sm text-red-800 text-center"><%= alert %></div>
    <% end %>

    <main class="flex-grow overflow-y-auto flex flex-col" style="view-transition-name: main-content;">
      <div class="flex-1">
        <%= yield %>
      </div>
      <%= render "components/footer" %>
    </main>
  </body>
</html>
