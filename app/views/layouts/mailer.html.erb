<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <style>
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1a1a1a; line-height: 1.6; margin: 0; padding: 0; background-color: #f5f5f5; }
      .container { max-width: 600px; margin: 0 auto; padding: 32px 24px; }
      .card { background: #ffffff; border-radius: 12px; padding: 32px; margin-bottom: 16px; }
      .header { text-align: center; padding-bottom: 24px; border-bottom: 1px solid #e5e5e5; margin-bottom: 24px; }
      .header h1 { font-size: 20px; font-weight: 600; margin: 0; }
      .detail { padding: 8px 0; }
      .detail-label { font-size: 13px; color: #737373; text-transform: uppercase; letter-spacing: 0.5px; }
      .detail-value { font-size: 16px; font-weight: 500; }
      .btn { display: inline-block; padding: 12px 32px; background: #171717; color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: 500; font-size: 14px; }
      .footer { text-align: center; padding-top: 24px; font-size: 13px; color: #a3a3a3; }
    </style>
  </head>

  <body>
    <div class="container">
      <div class="card">
        <%= yield %>
      </div>
      <div class="footer">
        <p>Digital Desk</p>
      </div>
    </div>
  </body>
</html>
