<!DOCTYPE html>
<html class="scroll-smooth">
  <head>
    <title><%= content_for(:title) || "D-Desk" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <meta name="view-transition" content="same-origin" />
  </head>

  <body class="bg-gray-50 text-gray-900 antialiased min-h-screen">
    <% if notice.present? %>
      <div class="fixed top-4 left-1/2 -translate-x-1/2 z-50 bg-green-50 border border-green-200 rounded-xl px-6 py-3 text-sm text-green-800 shadow-lg"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="fixed top-4 left-1/2 -translate-x-1/2 z-50 bg-red-50 border border-red-200 rounded-xl px-6 py-3 text-sm text-red-800 shadow-lg"><%= alert %></div>
    <% end %>

    <%= yield %>
  </body>
</html>
