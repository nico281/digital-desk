<% content_for :title, "Mi Panel" %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Welcome -->
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Hola, <%= @user.name.split(' ').first %></h1>
    <p class="text-gray-500 mt-1">Bienvenido a tu panel</p>
  </div>

  <!-- My Bookings -->
  <div class="card p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Mis próximas reservas</h2>
      <%= link_to search_path, class: "text-sm text-violet-600 hover:text-violet-700 font-medium", data: { turbo_action: "advance" } do %>
        Buscar profesionales →
      <% end %>
    </div>

    <% if @upcoming_bookings.any? %>
      <div class="space-y-4">
        <% @upcoming_bookings.each do |booking| %>
          <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl">
            <div class="flex items-center gap-4">
              <div class="avatar avatar-primary avatar-md">
                <%= booking.professional.user.name.first.upcase %>
              </div>
              <div>
                <p class="font-medium text-gray-900"><%= booking.service.title %></p>
                <p class="text-sm text-gray-500">con <%= booking.professional.user.name %></p>
              </div>
            </div>

            <div class="flex items-center gap-2">
              <span class="badge <%= booking.confirmed? ? 'badge-green' : 'badge-yellow' %>">
                <%= booking.confirmed? ? 'Confirmada' : 'Pendiente' %>
              </span>
              <%= link_to "Ver", booking_path(booking), class: "btn-secondary text-sm py-1.5 px-3", data: { turbo_action: "advance" } %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <%= render "components/empty_state",
          title: "No tienes reservas",
          message: "Explorá profesionales y reservá tu primera sesión",
          icon: "calendar" %>
    <% end %>
  </div>

  <% if @professional %>
    <div class="card p-6">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-lg font-semibold text-gray-900">Reservas recibidas</h2>
          <p class="text-sm text-gray-500 mt-1">Gestioná las reservas de tus clientes</p>
        </div>
        <%= link_to pro_bookings_path, class: "btn btn-primary text-sm py-2 px-4", data: { turbo_action: "advance" } do %>
          Ver reservas
          <svg class="w-4 h-4 ml-1 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
