<% content_for :title, "Mi Panel" %>

<div class="page-header">
  <div class="page-header-content">
    <h1 class="page-header-title">Hola, <%= @user.name %></h1>
    <p class="page-header-subtitle">Bienvenido a tu panel</p>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Sidebar -->
    <div class="lg:col-span-1">
      <div class="card p-6 mb-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="avatar avatar-primary avatar-lg">
            <%= @user.name&.first&.upcase || "?" %>
          </div>
          <div>
            <h2 class="font-semibold text-gray-900"><%= @user.name %></h2>
            <p class="text-sm text-gray-500"><%= @user.email %></p>
          </div>
        </div>

        <% if @user.professional %>
          <span class="badge badge-green">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Profesional
          </span>
          <%= link_to pro_setup_path, class: "mt-4 btn-secondary w-full justify-center text-sm", data: { turbo_action: "advance" } do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Gestionar perfil
          <% end %>
        <% else %>
          <div class="mt-3 p-4 bg-gradient-to-br from-violet-50 to-indigo-50 rounded-xl border border-violet-100">
            <p class="text-sm text-violet-900 font-medium mb-1">¿Querés ofrecer tus servicios?</p>
            <p class="text-xs text-violet-600 mb-3">Creá tu perfil y empezá a recibir reservas</p>
            <%= link_to pro_setup_path, class: "inline-flex items-center justify-center w-full gap-2 px-4 py-2.5 bg-violet-600 text-white text-sm font-medium rounded-lg hover:bg-violet-700 transition-colors", data: { turbo_action: "advance" } do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
              Empezar ahora
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- Quick Links -->
      <div class="card p-6">
        <h3 class="font-semibold text-gray-900 mb-4">Accesos rápidos</h3>
        <div class="space-y-2">
          <%= link_to search_path, class: "flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 text-gray-700", data: { turbo_action: "advance" } do %>
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            Buscar profesionales
          <% end %>

          <% if @user.professional %>
            <%= link_to pro_services_path, class: "flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 text-gray-700", data: { turbo_action: "advance" } do %>
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
              Mis servicios
            <% end %>

            <%= link_to pro_availability_schedules_path, class: "flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 text-gray-700", data: { turbo_action: "advance" } do %>
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              Mi disponibilidad
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="lg:col-span-2">
      <!-- My Bookings -->
      <div class="card p-6 mb-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Mis próximas reservas</h2>

        <% if @upcoming_bookings.any? %>
          <div class="space-y-4">
            <% @upcoming_bookings.each do |booking| %>
              <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl">
                <div class="flex items-center gap-4">
                  <div class="avatar avatar-primary avatar-md">
                    <%= booking.professional.user.name.first.upcase %>
                  </div>
                  <div>
                    <p class="font-medium text-gray-900"><%= booking.service.title %></p>
                    <p class="text-sm text-gray-500">con <%= booking.professional.user.name %></p>
                  </div>
                </div>

                <div class="text-right">
                  <span class="badge <%= booking.status == 'confirmed' ? 'badge-green' : 'badge-yellow' %>">
                    <%= booking.status.capitalize %>
                  </span>
                  <p class="text-sm text-gray-500 mt-1"><%= link_to "Ver detalles", booking_path(booking), class: "text-gray-700 hover:text-gray-900", data: { turbo_action: "advance" } %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <%= render "components/empty_state",
              title: "No tienes reservas",
              message: "Explorá profesionales y reservá tu primera sesión",
              icon: "calendar" %>
        <% end %>
      </div>

      <!-- Bookings as Professional (if applicable) -->
      <% if @professional %>
        <div class="card p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Reservas recibidas</h2>

          <% if @upcoming_bookings_as_pro&.any? %>
            <div class="space-y-4">
              <% @upcoming_bookings_as_pro.each do |booking| %>
                <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl">
                  <div class="flex items-center gap-4">
                    <div class="avatar avatar-primary avatar-md">
                      <%= booking.client.name.first.upcase %>
                    </div>
                    <div>
                      <p class="font-medium text-gray-900"><%= booking.service.title %></p>
                      <p class="text-sm text-gray-500">de <%= booking.client.name %></p>
                    </div>
                  </div>

                  <div class="text-right">
                    <span class="badge <%= booking.status == 'confirmed' ? 'badge-green' : 'badge-yellow' %>">
                      <%= booking.status.capitalize %>
                    </span>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-500 text-center py-8">Aún no tienes reservas como profesional</p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
