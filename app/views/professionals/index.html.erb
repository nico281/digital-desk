<% content_for :title, "Profesionales" %>

<div class="page-header">
  <div class="page-header-content">
    <h1 class="page-header-title">Todos los profesionales</h1>
    <p class="page-header-subtitle">Explorá nuestros expertos verificados</p>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Quick filters -->
  <div class="flex flex-wrap gap-2 mb-8">
    <%= link_to professionals_path, class: "badge badge-gray #{params[:category_id].blank? ? "!bg-gray-900 !text-white" : ""}", data: { turbo_action: "advance" } do %>
      Todos
    <% end %>

    <% @categories.each do |category| %>
      <%= link_to professionals_path(category_id: category.id),
          class: "badge badge-gray #{params[:category_id] == category.id.to_s ? "!bg-gray-900 !text-white" : ""}",
          data: { turbo_action: "advance" } do %>
        <%= category.name %>
      <% end %>
    <% end %>
  </div>

  <!-- Results -->
  <% if @professionals.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% @professionals.each do |professional| %>
        <%= render "components/professional_card", professional: %>
      <% end %>
    </div>

    <!-- Pagination -->
    <div class="mt-10 flex justify-center">
      <%= paginate @professionals, window: 2, outer_window: 1 %>
    </div>
  <% else %>
    <%= render "components/empty_state",
        title: "No hay profesionales aún",
        message: "Sé el primero en ofrecer tus servicios",
        icon: "calendar" %>
  <% end %>
</div>
