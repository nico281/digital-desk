<% content_for :title, @professional.user&.name %>

<!-- Cover -->
<div class="h-48 bg-gradient-to-br from-gray-800 to-gray-900"></div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 px-4 -mt-16">
  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Profile Card -->
    <div class="lg:w-80 flex-shrink-0">
      <div class="card shadow-lg overflow-hidden">
        <!-- Avatar -->
        <div class="p-6 flex flex-col items-center text-center border-b border-gray-100">
          <div class="w-24 h-24 rounded-2xl bg-gradient-to-br from-gray-700 to-gray-900 flex items-center justify-center text-white text-3xl font-bold mb-4">
            <%= @professional.user&.name&.first&.upcase || "?" %>
          </div>

          <h1 class="text-xl font-bold text-gray-900"><%= @professional.user&.name %></h1>
          <p class="text-gray-500 mt-1"><%= @professional.headline %></p>

          <div class="flex items-center gap-2 mt-3">
            <% if @professional.rating_count > 0 %>
              <div class="flex items-center gap-1">
                <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                <span class="font-semibold"><%= @professional.rating_avg %></span>
                <span class="text-gray-400">(<%= @professional.rating_count %>)</span>
              </div>
            <% end %>

            <% if @professional.verified? %>
              <span class="badge badge-blue">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                Verificado
              </span>
            <% end %>
          </div>
        </div>

        <!-- Bio -->
        <div class="p-6 border-b border-gray-100">
          <h3 class="font-semibold text-gray-900 mb-2">Sobre mí</h3>
          <p class="text-sm text-gray-600 leading-relaxed"><%= @professional.bio %></p>
        </div>

        <!-- Categories -->
        <% if @professional.categories.any? %>
          <div class="p-6">
            <h3 class="font-semibold text-gray-900 mb-3">Especialidades</h3>
            <div class="flex flex-wrap gap-2">
              <% @professional.categories.each do |category| %>
                <%= link_to category.name, search_path(category: category.slug), class: "badge badge-gray", data: { turbo_action: "advance" } %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Main Content -->
    <div class="flex-1">
      <!-- Services -->
      <div class="card p-6 mb-6">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Servicios</h2>

        <% if @services.any? %>
          <div class="space-y-4">
            <% @services.each do |service| %>
              <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors">
                <div>
                  <h3 class="font-semibold text-gray-900"><%= service.title %></h3>
                  <p class="text-sm text-gray-500 mt-1"><%= service.description %></p>
                  <div class="flex items-center gap-3 mt-2 text-sm text-gray-500">
                    <span class="flex items-center gap-1">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      <%= service.duration_minutes %> min
                    </span>
                    <% if service.category %>
                      <span class="flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                        </svg>
                        <%= service.category.name %>
                      </span>
                    <% end %>
                  </div>
                </div>

                <div class="text-right">
                  <p class="text-2xl font-bold text-gray-900">
                    <%= number_to_currency(service.price, unit: "$", precision: 0) %>
                  </p>
                  <%= link_to "Reservar",
                      slots_professional_path(@professional, service_id: service.id, date: Date.tomorrow),
                      data: { turbo_frame: "slots_#{service.id}" },
                      class: "inline-block mt-2 btn-primary text-sm py-2 px-4" %>
                </div>
              </div>
              <turbo-frame id="slots_<%= service.id %>"></turbo-frame>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500">Este profesional aún no tiene servicios disponibles.</p>
        <% end %>
      </div>

      <!-- Reviews -->
      <div class="card p-6">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Reseñas</h2>

        <% if @reviews.any? %>
          <div class="space-y-6">
            <% @reviews.each do |review| %>
              <div class="border-b border-gray-100 pb-6 last:border-0 last:pb-0">
                <div class="flex items-start justify-between">
                  <div class="flex items-center gap-3">
                    <div class="avatar avatar-primary avatar-sm">
                      <%= review.client&.name&.first&.upcase || "?" %>
                    </div>
                    <div>
                      <p class="font-medium text-gray-900"><%= review.client&.name %></p>
                      <div class="flex items-center gap-1">
                        <% 5.times do |i| %>
                          <% star_color = i < review.rating ? "text-yellow-400" : "text-gray-200" %>
                          <svg class="w-4 h-4 <%= star_color %>" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                          </svg>
                        <% end %>
                      </div>
                    </div>
                  </div>
                  <span class="text-sm text-gray-400"><%= time_ago_in_words(review.created_at) %></span>
                </div>
                <% if review.comment.present? %>
                  <p class="text-gray-600 mt-3"><%= review.comment %></p>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500">Aún no hay reseñas.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
