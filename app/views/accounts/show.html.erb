<% content_for :title, "Mi cuenta" %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Mi cuenta</h1>

  <%= form_with model: current_user, url: account_path, method: :patch, class: "space-y-6" do |f| %>
    <% if current_user.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-xl p-4">
        <ul class="text-sm text-red-700 space-y-1">
          <% current_user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="card p-6 space-y-6">
      <h2 class="text-lg font-semibold text-gray-900">Foto de perfil</h2>

      <div class="flex items-center gap-6">
        <div id="avatar-preview">
          <%= user_avatar(current_user, size: :xl) %>
        </div>
        <div class="flex-1">
          <%= f.file_field :avatar,
            accept: "image/png,image/jpeg,image/webp",
            class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-gray-900 file:text-white hover:file:bg-gray-800 file:cursor-pointer",
            data: { controller: "preview", preview_target_value: "avatar-preview", action: "change->preview#show" } %>
          <p class="text-xs text-gray-400 mt-2">JPG, PNG o WebP. Max 5MB.</p>
        </div>
      </div>

      <div>
        <label for="user_name" class="block text-sm font-medium text-gray-700 mb-1">Nombre</label>
        <%= f.text_field :name, class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-gray-500 focus:ring-gray-500" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
        <p class="text-gray-500 text-sm"><%= current_user.email %></p>
      </div>
    </div>

    <div class="flex justify-end">
      <%= f.submit "Guardar", class: "btn btn-primary py-3 px-8 cursor-pointer" %>
    </div>
  <% end %>
</div>
