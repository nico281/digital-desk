<% if notice.present? %>
  <div data-controller="toast" data-toast-duration-value="4000"
       class="toast bg-white border border-green-200 text-green-800 shadow-lg rounded-xl px-5 py-3 text-sm font-medium flex items-center gap-2">
    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
    </svg>
    <span><%= notice %></span>
    <button data-action="toast#dismiss" class="ml-auto text-green-400 hover:text-green-600 cursor-pointer">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
<% end %>

<% if alert.present? %>
  <div data-controller="toast" data-toast-duration-value="6000"
       class="toast bg-white border border-red-200 text-red-800 shadow-lg rounded-xl px-5 py-3 text-sm font-medium flex items-center gap-2">
    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M12 3a9 9 0 110 18 9 9 0 010-18z"/>
    </svg>
    <span><%= alert %></span>
    <button data-action="toast#dismiss" class="ml-auto text-red-400 hover:text-red-600 cursor-pointer">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
<% end %>
