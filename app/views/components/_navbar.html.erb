<nav class="bg-white/80 backdrop-blur-md border-b border-gray-200" style="view-transition-name: navbar;" data-controller="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <%= link_to root_path, class: "flex items-center gap-2", data: { turbo_action: "advance" } do %>
        <div class="w-8 h-8 bg-gray-900 rounded-lg flex items-center justify-center">
          <span class="text-white font-bold text-sm">D</span>
        </div>
        <span class="font-semibold text-xl tracking-tight">D-Desk</span>
      <% end %>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-6">
        <%= link_to "Buscar profesionales", search_path, class: "text-gray-600 hover:text-gray-900 font-medium transition-colors", data: { turbo_action: "advance" } %>
      </div>

      <!-- Auth / User -->
      <div class="flex items-center gap-3">
        <% if user_signed_in? %>
          <%= link_to "Mi Panel", dashboard_path, class: "hidden sm:block px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors", data: { turbo_action: "advance" } %>
          <%= button_to "Cerrar", destroy_user_session_path, method: :delete, class: "px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors" %>
        <% else %>
          <%= link_to "Ingresar", new_user_session_path, class: "px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors", data: { turbo_action: "advance" } %>
          <%= link_to "Registrarse", new_user_registration_path, class: "px-4 py-2 text-sm font-medium text-white bg-gray-900 rounded-lg hover:bg-gray-800 transition-colors", data: { turbo_action: "advance" } %>
        <% end %>

        <!-- Mobile menu button -->
        <button type="button" class="md:hidden p-2 rounded-lg hover:bg-gray-100" data-action="click->navbar#toggle" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div class="md:hidden hidden pb-4" data-navbar-target="menu">
      <div class="flex flex-col gap-2 pt-2 border-t border-gray-100">
        <%= link_to "Buscar profesionales", search_path, class: "px-3 py-2 text-gray-700 hover:bg-gray-50 rounded-lg", data: { turbo_action: "advance" } %>
        <% if user_signed_in? %>
          <%= link_to "Mi Panel", dashboard_path, class: "px-3 py-2 text-gray-700 hover:bg-gray-50 rounded-lg", data: { turbo_action: "advance" } %>
        <% end %>
      </div>
    </div>
  </div>
</nav>
