<%= link_to professional_path(professional), class: "group block bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-lg hover:border-gray-300 transition-all duration-300", data: { turbo_action: "advance" } do %>
  <!-- Header: Avatar + Info -->
  <div class="p-5">
    <div class="flex items-start gap-4">
      <!-- Avatar -->
      <div class="flex-shrink-0">
        <%= user_avatar(professional.user, size: :lg) %>
      </div>

      <!-- Info -->
      <div class="flex-1 min-w-0">
        <h3 class="font-semibold text-gray-900 group-hover:text-gray-700 transition-colors truncate">
          <%= professional.user&.name %>
        </h3>
        <p class="text-sm text-gray-500 truncate"><%= professional.headline %></p>

        <!-- Rating -->
        <div class="flex items-center gap-1 mt-1">
          <% if professional.rating_count > 0 %>
            <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <span class="text-sm font-medium"><%= professional.rating_avg %></span>
            <span class="text-sm text-gray-400">(<%= professional.rating_count %>)</span>
          <% else %>
            <span class="text-xs text-gray-400">Sin reseñas</span>
          <% end %>

          <% if professional.verified? %>
            <svg class="w-4 h-4 text-blue-500 ml-1" fill="currentColor" viewBox="0 0 20 20" title="Verificado">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Categories -->
    <% if professional.categories.any? %>
      <div class="flex flex-wrap gap-1.5 mt-3">
        <% professional.categories.first(3).each do |category| %>
          <span class="px-2 py-1 text-xs bg-gray-100 text-gray-600 rounded-md">
            <%= category.name %>
          </span>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Footer: Starting price -->
  <% if (service = professional.services.select(&:active?).min_by(&:price)) %>
    <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-between">
      <span class="text-sm text-gray-500">Desde</span>
      <span class="font-semibold text-gray-900">
        <%= number_to_currency(service.price, unit: "$", precision: 0) %>
      </span>
    </div>
  <% end %>
<% end %>
