<%= link_to search_path(category: category.slug), class: "group p-6 bg-white rounded-2xl border border-gray-200 hover:border-gray-400 hover:shadow-lg transition-all duration-300", data: { turbo_action: "advance" } do %>
  <div class="flex items-center gap-4">
    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center text-gray-600">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
      </svg>
    </div>
    <div>
      <h3 class="font-semibold text-gray-900 group-hover:text-gray-700 transition-colors">
        <%= category.name %>
      </h3>
      <p class="text-sm text-gray-500">
        <%= category.children.count %> subcategorías
      </p>
    </div>
  </div>
<% end %>
