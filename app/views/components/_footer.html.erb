          <li><a href="#" class="hover:text-white transition-colors">Cómo funciona</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-800 text-sm text-center">
      <p>&copy; <%= Time.current.year %> D-Desk. Hecho con Rails 8.</p>
    </div>
