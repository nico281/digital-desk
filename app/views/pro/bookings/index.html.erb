<% content_for :title, "Reservas recibidas" %>

<% status_labels = { "pending" => "Pendientes", "confirmed" => "Confirmadas", "completed" => "Finalizadas", "cancelled" => "Canceladas" } %>
<% status_badges = { "pending" => "badge-yellow", "confirmed" => "badge-green", "completed" => "badge-blue", "cancelled" => "badge-gray" } %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Reservas recibidas</h1>
    <p class="text-sm text-gray-500 mt-1">Gestioná las reservas de tus clientes</p>
  </div>
  <!-- Filters -->
  <div class="flex flex-wrap gap-2 mb-6">
    <%= link_to "Todas", pro_bookings_path, class: "badge #{@filter.blank? ? 'bg-gray-900 text-white' : 'badge-gray'}", data: { turbo_action: "replace" } %>
    <% status_labels.each do |status, label| %>
      <%= link_to label, pro_bookings_path(status: status), class: "badge #{@filter == status ? 'bg-gray-900 text-white' : 'badge-gray'}", data: { turbo_action: "replace" } %>
    <% end %>
  </div>

  <% if @bookings.any? %>
    <div class="space-y-4">
      <% @bookings.each do |booking| %>
        <div class="card p-6 flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div class="avatar avatar-primary avatar-md">
              <%= booking.client.name&.first&.upcase || "?" %>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900"><%= booking.service.title %></h3>
              <p class="text-sm text-gray-500"><%= booking.client.name %></p>
              <% if booking.date %>
                <p class="text-sm text-gray-400 mt-1">
                  <%= l(booking.date, format: :long) %> · <%= booking.start_time&.strftime("%H:%M") %> — <%= booking.end_time&.strftime("%H:%M") %>
                </p>
              <% end %>
            </div>
          </div>

          <div class="flex items-center gap-3">
            <span class="badge <%= status_badges[booking.status] %>">
              <%= status_labels[booking.status] || booking.status.capitalize %>
            </span>
            <% if booking.pending? %>
              <%= button_to "Confirmar", confirm_pro_booking_path(booking), method: :post, class: "btn btn-primary text-sm py-2 px-3", data: { turbo_confirm: "¿Confirmar esta reserva?" } %>
              <%= button_to "Rechazar", reject_pro_booking_path(booking), method: :post, class: "btn-secondary text-sm py-2 px-3 text-red-600 border-red-200 hover:bg-red-50", data: { turbo_confirm: "¿Rechazar esta reserva?" } %>
            <% end %>
            <%= link_to "Ver", booking_path(booking, from: "pro"), class: "btn-secondary text-sm py-2 px-3", data: { turbo_action: "advance" } %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "components/empty_state",
        title: @filter.present? ? "Sin reservas #{status_labels[@filter]&.downcase}" : "Sin reservas",
        message: "Las reservas de tus clientes aparecerán acá",
        icon: "calendar" %>
  <% end %>
</div>
