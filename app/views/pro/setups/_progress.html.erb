<% labels = ["Perfil", "Servicio", "Horario"] %>

<div class="mb-10">
  <div class="flex items-center">
    <% (1..3).each do |i| %>
      <div class="flex items-center flex-1">
        <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-full flex items-center justify-center text-sm font-bold shrink-0
          <% if i < @step %>bg-green-500 text-white
          <% elsif i == @step %>bg-violet-600 text-white ring-4 ring-violet-100
          <% else %>bg-gray-200 text-gray-400<% end %>">
          <% if i < @step %>
            <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            </svg>
          <% else %>
            <%= i %>
          <% end %>
        </div>
        <% if i < 3 %>
          <div class="flex-1 h-0.5 mx-3 <%= i < @step ? 'bg-green-500' : 'bg-gray-200' %>"></div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="flex items-center mt-2">
    <% labels.each_with_index do |label, i| %>
      <div class="flex-1 text-center">
        <span class="text-xs font-medium whitespace-nowrap
          <% if i + 1 == @step %>text-violet-600
          <% elsif i + 1 < @step %>text-green-600
          <% else %>text-gray-400<% end %>">
          <%= label %>
        </span>
      </div>
    <% end %>
  </div>
</div>
