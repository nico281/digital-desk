<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">¿Cuándo atendés?</h1>
    <p class="text-sm text-gray-500 mt-1">Configurá tu disponibilidad para que los clientes puedan reservar</p>
  </div>

  <%= form_with url: pro_setup_path(step: 3), method: :patch, class: "space-y-6" do |f| %>
    <div class="card p-6 space-y-4">
      <h2 class="text-lg font-semibold text-gray-900">Duración de cada turno</h2>
      <p class="text-sm text-gray-500">¿Cuánto dura cada sesión con tus clientes?</p>

      <div class="flex flex-wrap gap-3">
        <% [15, 30, 45, 60].each do |mins| %>
          <label class="cursor-pointer">
            <input type="radio" name="professional[block_duration_minutes]" value="<%= mins %>"
                   <%= "checked" if mins == 60 %>
                   class="peer sr-only">
            <span class="inline-block px-5 py-2.5 rounded-xl border-2 border-gray-200 text-sm font-medium peer-checked:border-violet-600 peer-checked:bg-violet-50 peer-checked:text-violet-700 hover:border-gray-300 transition-all">
              <%= mins %> min
            </span>
          </label>
        <% end %>
      </div>
    </div>

    <div class="card p-6 space-y-4">
      <h2 class="text-lg font-semibold text-gray-900">Elegí tus horarios</h2>
      <p class="text-sm text-gray-500">Seleccioná un horario predefinido. Podés cambiarlo después.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <% @presets.each do |key, preset| %>
          <label class="cursor-pointer">
            <input type="radio" name="preset" value="<%= key %>" class="peer sr-only">
            <span class="block p-4 rounded-xl border-2 border-gray-200 peer-checked:border-violet-600 peer-checked:bg-violet-50 transition-all hover:border-gray-300">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-gray-100 peer-checked:bg-violet-100 flex items-center justify-center shrink-0 transition-colors">
                  <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <span class="text-sm font-medium text-gray-700"><%= preset[:label] %></span>
              </div>
            </span>
          </label>
        <% end %>
      </div>
    </div>

    <div class="flex items-center justify-between">
      <%= link_to "← Anterior", pro_setup_path(step: 2), class: "text-sm text-gray-500 hover:text-gray-700", data: { turbo_action: "advance" } %>
      <%= submit_tag "Terminar →", class: "btn btn-primary py-3 px-8 cursor-pointer" %>
    </div>
    <p class="text-xs text-gray-400 text-center">Podés dejarlo vacío y configurar horarios después</p>
  <% end %>
</div>
