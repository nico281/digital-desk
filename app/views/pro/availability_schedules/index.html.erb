<% content_for :title, "Mi disponibilidad" %>

<% day_names = %w[Domingo Lunes Martes Miércoles Jueves Viernes Sábado] %>

<div class="page-header">
  <div class="page-header-content flex items-center justify-between">
    <div>
      <h1 class="page-header-title">Mi disponibilidad</h1>
      <p class="page-header-subtitle">Configurá tus horarios semanales recurrentes</p>
    </div>
    <%= link_to new_pro_availability_schedule_path, class: "btn-primary bg-white text-gray-900 hover:bg-gray-100", data: { turbo_action: "advance" } do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
      </svg>
      Agregar horario
    <% end %>
  </div>
</div>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Configuración de bloques -->
  <div class="card p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-lg font-semibold text-gray-900">Configuración de bloques</h2>
        <p class="text-sm text-gray-500">Definí la duración de cada turno y el descanso entre turnos</p>
      </div>
      <% if @blocks_count > 0 %>
        <span class="badge badge-blue"><%= @blocks_count %> bloques disponibles</span>
      <% end %>
    </div>

    <%= form_with model: @professional, url: pro_block_settings_path, method: :patch, class: "flex flex-wrap items-end gap-4" do |f| %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Duración del turno</label>
        <%= f.select :block_duration_minutes,
            [["15 minutos", 15], ["30 minutos", 30], ["45 minutos", 45], ["1 hora", 60]],
            {},
            class: "rounded-xl border-gray-300 focus:border-gray-500 focus:ring-gray-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Descanso entre turnos</label>
        <%= f.select :buffer_minutes,
            [["Sin descanso", 0], ["5 minutos", 5], ["10 minutos", 10], ["15 minutos", 15]],
            {},
            class: "rounded-xl border-gray-300 focus:border-gray-500 focus:ring-gray-500" %>
      </div>
      <%= f.submit "Guardar", class: "btn-primary cursor-pointer" %>
    <% end %>
  </div>

  <% if @schedules.any? %>
    <div class="space-y-4">
      <% (1..6).to_a.push(0).each do |day| %>
        <% schedules = @schedules_by_day[day] %>
        <% next unless schedules %>

        <div class="card p-6">
          <h3 class="font-semibold text-gray-900 mb-3"><%= day_names[day] %></h3>
          <div class="space-y-2">
            <% schedules.each do |schedule| %>
              <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl">
                <div class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span class="text-gray-700 font-medium">
                    <%= schedule.start_time.strftime("%H:%M") %> — <%= schedule.end_time.strftime("%H:%M") %>
                  </span>
                </div>
                <div class="flex items-center gap-2">
                  <%= link_to edit_pro_availability_schedule_path(schedule), class: "text-gray-400 hover:text-gray-600", data: { turbo_action: "advance" } do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                  <% end %>
                  <%= button_to pro_availability_schedule_path(schedule), method: :delete, class: "text-gray-400 hover:text-red-600", data: { turbo_confirm: "¿Eliminar este horario?" } do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "components/empty_state",
        title: "Sin horarios configurados",
        message: "Agregá tus horarios semanales para que los clientes puedan reservar",
        icon: "calendar" %>
    <div class="text-center mt-4">
      <%= link_to "Agregar horario", new_pro_availability_schedule_path, class: "btn-primary", data: { turbo_action: "advance" } %>
    </div>
  <% end %>

  <!-- Manual Blocks Section -->
  <div class="mt-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Bloqueos manuales</h2>
      <button type="button" class="btn-secondary text-sm" data-controller="toggle" data-action="toggle#toggle" data-toggle-target-value="block-form">
        Bloquear fecha
      </button>
    </div>

    <div id="block-form" class="card p-6 mb-4 hidden">
      <%= form_with url: pro_availability_blocks_path, method: :post, class: "flex flex-wrap items-end gap-4" do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Fecha</label>
          <%= f.date_field :date, min: Date.today, class: "rounded-xl border-gray-300 focus:border-gray-500 focus:ring-gray-500" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Desde</label>
          <%= f.time_field :start_time, class: "rounded-xl border-gray-300 focus:border-gray-500 focus:ring-gray-500" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Hasta</label>
          <%= f.time_field :end_time, class: "rounded-xl border-gray-300 focus:border-gray-500 focus:ring-gray-500" %>
        </div>
        <%= f.submit "Bloquear", class: "btn-primary cursor-pointer" %>
      <% end %>
    </div>

    <% blocks = @professional.availability_blocks.blocked.where("date >= ?", Date.today).order(:date, :start_time) %>
    <% if blocks.any? %>
      <div class="space-y-2">
        <% blocks.each do |block| %>
          <div class="flex items-center justify-between p-3 bg-red-50 border border-red-100 rounded-xl">
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
              </svg>
              <span class="text-red-700 font-medium">
                <%= l(block.date, format: :long) %> · <%= block.start_time.strftime("%H:%M") %> — <%= block.end_time.strftime("%H:%M") %>
              </span>
            </div>
            <%= button_to pro_availability_block_path(block), method: :delete, class: "text-red-400 hover:text-red-600", data: { turbo_confirm: "¿Desbloquear?" } do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-400">No hay bloqueos manuales activos</p>
    <% end %>
  </div>
</div>
