<% content_for :title, "Mi disponibilidad" %>

<% day_names = %w[Domingo Lunes Martes Miércoles Jueves Viernes Sábado] %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Mi disponibilidad</h1>
      <p class="text-sm text-gray-500 mt-1">Configurá tus horarios semanales recurrentes</p>
    </div>
    <%= link_to new_pro_availability_schedule_path, class: "btn-primary", data: { turbo_action: "advance" } do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
      </svg>
      Agregar horario
    <% end %>
  </div>
  <!-- Configuración de bloques -->
  <div class="card p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-lg font-semibold text-gray-900">Configuración de bloques</h2>
        <p class="text-sm text-gray-500">Definí la duración de cada turno y el descanso entre turnos</p>
      </div>
      <% if @blocks_count > 0 %>
        <span class="badge badge-blue"><%= @blocks_count %> bloques disponibles</span>
      <% end %>
    </div>

    <%= form_with model: @professional, url: pro_block_settings_path, method: :patch, class: "flex flex-wrap items-end gap-4" do |f| %>
      <% if @professional.errors[:block_duration_minutes].any? || @professional.errors[:buffer_minutes].any? %>
        <div class="w-full bg-red-50 border border-red-200 rounded-xl p-4">
          <ul class="text-sm text-red-700 space-y-1">
            <% @professional.errors[:block_duration_minutes].each do |msg| %>
              <li><%= msg %></li>
            <% end %>
            <% @professional.errors[:buffer_minutes].each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Duración del turno</label>
        <%= f.select :block_duration_minutes,
            [["15 minutos", 15], ["30 minutos", 30], ["45 minutos", 45], ["1 hora", 60]],
            {},
            class: "rounded-xl border border-gray-300 px-4 py-3 focus:border-gray-500 focus:ring-gray-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Descanso entre turnos</label>
        <%= f.select :buffer_minutes,
            [["Sin descanso", 0], ["5 minutos", 5], ["10 minutos", 10], ["15 minutos", 15]],
            {},
            class: "rounded-xl border border-gray-300 px-4 py-3 focus:border-gray-500 focus:ring-gray-500" %>
      </div>
      <%= f.submit "Guardar", class: "btn btn-primary py-3 px-8 cursor-pointer" %>
    <% end %>
  </div>

  <!-- Presets -->
  <div class="card p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-1">Horarios predefinidos</h2>
    <p class="text-sm text-gray-500 mb-4">Hacé clic para crear varios horarios de una vez</p>
    <div class="flex flex-wrap gap-3">
      <% @presets.each do |key, preset| %>
        <%= form_with url: batch_pro_availability_schedules_path, method: :post, class: "inline" do |f| %>
          <% preset[:schedules].each do |s| %>
            <% s.each do |k, v| %>
              <%= hidden_field_tag "schedules[][#{k}]", v %>
            <% end %>
          <% end %>
          <%= button_tag preset[:label], class: "border border-gray-200 rounded-xl px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-900 hover:text-white hover:border-gray-900 transition-colors cursor-pointer" %>
        <% end %>
      <% end %>
    </div>
  </div>

  <%= render "schedule_list", schedules: @schedules, schedules_by_day: @schedules_by_day, animated: false %>

  <!-- Manual Blocks Section -->
  <div class="mt-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Bloqueos manuales</h2>
      <button type="button" class="btn-secondary text-sm" data-controller="toggle" data-action="toggle#toggle" data-toggle-target-value="block-form">
        Bloquear fecha
      </button>
    </div>

    <div id="block-form" class="card p-6 mb-4 hidden">
      <%= form_with url: pro_availability_blocks_path, method: :post, class: "flex flex-wrap items-end gap-4" do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Fecha</label>
          <%= f.date_field :date, min: Date.today, class: "rounded-xl border border-gray-300 px-4 py-3 focus:border-gray-500 focus:ring-gray-500" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Desde</label>
          <%= f.time_field :start_time, class: "rounded-xl border border-gray-300 px-4 py-3 focus:border-gray-500 focus:ring-gray-500" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Hasta</label>
          <%= f.time_field :end_time, class: "rounded-xl border border-gray-300 px-4 py-3 focus:border-gray-500 focus:ring-gray-500" %>
        </div>
        <%= f.submit "Bloquear", class: "btn btn-primary py-3 px-8 cursor-pointer" %>
      <% end %>
    </div>

    <% blocks = @professional.availability_blocks.blocked.where("date >= ?", Date.today).order(:date, :start_time) %>
    <% if blocks.any? %>
      <div class="space-y-2">
        <% blocks.each do |block| %>
          <div class="flex items-center justify-between p-3 bg-red-50 border border-red-100 rounded-xl">
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
              </svg>
              <span class="text-red-700 font-medium">
                <%= l(block.date, format: :long) %> · <%= block.start_time.strftime("%H:%M") %> — <%= block.end_time.strftime("%H:%M") %>
              </span>
            </div>
            <%= button_to pro_availability_block_path(block), method: :delete, class: "text-red-400 hover:text-red-600", data: { turbo_confirm: "¿Desbloquear?" } do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-400">No hay bloqueos manuales activos</p>
    <% end %>
  </div>
</div>
