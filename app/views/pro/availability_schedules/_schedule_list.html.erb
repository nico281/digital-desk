<% day_names = %w[Domingo Lunes Martes Miércoles Jueves Viernes Sábado] %>

<%= turbo_frame_tag "schedule-list" do %>
  <div id="schedule-list-content" class="<%= "animate-on-update" if animated %>">
  <% if schedules.any? %>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900"><%= schedules.count %> horario(s) configurado(s)</h2>
      <%= button_to "Eliminar todos", reset_pro_availability_schedules_path, method: :delete,
            class: "text-sm text-red-600 hover:text-red-800 font-medium cursor-pointer",
            data: { turbo_confirm: "¿Estás seguro? Se eliminarán todos los horarios configurados." } %>
    </div>
    <div class="space-y-4">
      <% (1..6).to_a.push(0).each do |day| %>
        <% day_schedules = schedules_by_day[day] %>
        <% next unless day_schedules %>

        <div class="card p-6">
          <h3 class="font-semibold text-gray-900 mb-3"><%= day_names[day] %></h3>
          <div class="space-y-2">
            <% day_schedules.each do |schedule| %>
              <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl">
                <div class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span class="text-gray-700 font-medium">
                    <%= schedule.start_time.strftime("%H:%M") %> — <%= schedule.end_time.strftime("%H:%M") %>
                  </span>
                </div>
                <div class="flex items-center gap-2">
                  <%= link_to edit_pro_availability_schedule_path(schedule), class: "text-gray-400 hover:text-gray-600", data: { turbo_action: "advance" } do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                  <% end %>
                  <%= button_to pro_availability_schedule_path(schedule), method: :delete, class: "text-gray-400 hover:text-red-600", data: { turbo_confirm: "¿Eliminar este horario?" } do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "components/empty_state",
        title: "Sin horarios configurados",
        message: "Agregá tus horarios semanales para que los clientes puedan reservar",
        icon: "calendar" %>
    <div class="text-center mt-4">
      <%= link_to "Agregar horario", new_pro_availability_schedule_path, class: "btn-primary", data: { turbo_action: "advance" } %>
    </div>
  <% end %>
  </div>
<% end %>
