<% day_names = %w[Domingo Lunes Martes Miércoles Jueves Viernes Sábado] %>

<%= form_with model: [:pro, schedule], class: "space-y-6" do |f| %>
  <% if schedule.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-4">
      <ul class="text-sm text-red-700 space-y-1">
        <% schedule.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card p-6 space-y-6">
    <div>
      <label for="availability_schedule_day_of_week" class="block text-sm font-medium text-gray-700 mb-1">Día de la semana</label>
      <%= f.select :day_of_week, day_names.each_with_index.map { |name, i| [name, i] }, {}, class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-gray-500 focus:ring-gray-500" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label for="availability_schedule_start_time" class="block text-sm font-medium text-gray-700 mb-1">Hora inicio</label>
        <%= f.time_field :start_time, step: 900, class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-gray-500 focus:ring-gray-500" %>
      </div>

      <div>
        <label for="availability_schedule_end_time" class="block text-sm font-medium text-gray-700 mb-1">Hora fin</label>
        <%= f.time_field :end_time, step: 900, class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-gray-500 focus:ring-gray-500" %>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-between">
    <%= link_to "Cancelar", pro_availability_schedules_path, class: "text-sm text-gray-500 hover:text-gray-700", data: { turbo_action: "advance" } %>
    <%= f.submit schedule.persisted? ? "Guardar cambios" : "Agregar horario", class: "btn btn-primary py-3 px-8 cursor-pointer" %>
  </div>
<% end %>
