<%= form_with model: [:pro, service], class: "space-y-6" do |f| %>
  <% if service.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-4">
      <ul class="text-sm text-red-700 space-y-1">
        <% service.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card p-6 space-y-6">
    <h2 class="text-lg font-semibold text-gray-900">Información del servicio</h2>

    <div>
      <label for="service_title" class="block text-sm font-medium text-gray-700 mb-1">Título</label>
      <%= f.text_field :title, placeholder: "Ej: Clase particular de Matemática", class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-gray-500 focus:ring-gray-500" %>
    </div>

    <div>
      <label for="service_description" class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
      <%= f.text_area :description, rows: 4, placeholder: "Describí qué incluye este servicio...", class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-gray-500 focus:ring-gray-500" %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label for="service_price" class="block text-sm font-medium text-gray-700 mb-1">Precio (ARS)</label>
        <%= f.number_field :price, min: 1, step: 1, placeholder: "5000", class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-gray-500 focus:ring-gray-500" %>
        <p class="text-xs text-gray-400 mt-1">Precio neto que recibís</p>
      </div>

      <div>
        <label for="service_duration_minutes" class="block text-sm font-medium text-gray-700 mb-1">Duración (min)</label>
        <%= f.number_field :duration_minutes, min: 15, step: 15, placeholder: "60", class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-gray-500 focus:ring-gray-500" %>
      </div>

      <div>
        <label for="service_category_id" class="block text-sm font-medium text-gray-700 mb-1">Categoría</label>
        <%= f.collection_select :category_id, @categories, :id, :name, { include_blank: "Sin categoría" }, class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-gray-500 focus:ring-gray-500" %>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-between">
    <%= link_to "Cancelar", pro_services_path, class: "text-sm text-gray-500 hover:text-gray-700", data: { turbo_action: "advance" } %>
    <%= f.submit service.persisted? ? "Guardar cambios" : "Crear servicio", class: "btn btn-primary py-3 px-8 cursor-pointer" %>
  </div>
<% end %>
